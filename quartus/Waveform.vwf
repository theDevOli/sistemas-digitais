/*<simulation_settings>
<ftestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off cronometro -c cronometro --vector_source="/home/daniel/sistemas-digitais/quartus/Waveform.vwf" --testbench_file="/home/daniel/sistemas-digitais/quartus/simulation/qsim/Waveform.vwf.vht"</ftestbench_cmd>
<ttestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off cronometro -c cronometro --vector_source="/home/daniel/sistemas-digitais/quartus/Waveform.vwf" --testbench_file="/home/daniel/sistemas-digitais/quartus/simulation/qsim/Waveform.vwf.vht"</ttestbench_cmd>
<fnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=on --flatten_buses=off --tool=modelsim_oem --format=vhdl --output_directory="/home/daniel/sistemas-digitais/quartus/simulation/qsim/" cronometro -c cronometro</fnetlist_cmd>
<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=vhdl --output_directory="/home/daniel/sistemas-digitais/quartus/simulation/qsim/" cronometro -c cronometro</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
vlib work
vcom -work work cronometro.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -L cyclonev -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.cronometro_vhd_vec_tst
vcd file -direction cronometro.msim.vcd
vcd add -internal cronometro_vhd_vec_tst/*
vcd add -internal cronometro_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script>
<modelsim_script_timing>onerror {exit -code 1}
vlib work
vcom -work work cronometro.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -sdfmax cronometro_vhd_vec_tst/i1=cronometro_vhd.sdo -L cyclonev -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.cronometro_vhd_vec_tst
vcd file -direction cronometro.msim.vcd
vcd add -internal cronometro_vhd_vec_tst/*
vcd add -internal cronometro_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script_timing>
<hdl_lang>vhdl</hdl_lang>
</simulation_settings>*/
